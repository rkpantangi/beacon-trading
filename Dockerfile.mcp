FROM python:3.12-slim

WORKDIR /app

# Install uv for managing dependencies
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

# Copy the entire project
COPY . .

# Expose Fly.io default port
EXPOSE 8080

# Environment variables for Fly.io routing and transport
ENV TRADING_MCP_HOST=0.0.0.0
ENV TRADING_MCP_PORT=8080
ENV TRADING_MCP_TRANSPORT=http
ENV TRADING_API_MODE=http

# Start the MCP server using the streamable HTTP transport
CMD ["uv", "run", "--directory", "mcp_server", "beacon-trading-mcp-server"]
